# ─── Server ───────────────────────────────────
NODE_ENV=production
PORT=3000
BASE_URL=https://paycontrol.swiftwaveholding.com

# ─── MongoDB ──────────────────────────────────
# Local MongoDB (ensure mongod is running)
MONGODB_URI=mongodb://127.0.0.1:27017/paycontrol

# Alternative: MongoDB Atlas (uncomment and fill if using cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/paycontrol

# ─── JWT ──────────────────────────────────────
JWT_SECRET=a7f9e2d4c6b1f3h5j7k9m2n4p6q8r0s2t4u6v8w0x2y4z6a8b0c2d4e6f8g0h2
JWT_EXPIRES_IN=7d

# ─── Session ──────────────────────────────────
SESSION_SECRET=b8g0f3e5d7c9b1a3f5h7j9k1m3n5p7q9r1s3t5u7v9w1x3y5z7a9b1c3d5e7f9

# ─── GitHub OAuth App ─────────────────────────
# Get these from https://github.com/settings/apps/your-app-name
GITHUB_CLIENT_ID=Iv1.YOUR_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=ghp_YOUR_CLIENT_SECRET_HERE
GITHUB_CALLBACK_URL=https://paycontrol.swiftwaveholding.com/oauth/callback

# ─── GitHub App ───────────────────────────────
# App ID from GitHub App settings
GITHUB_APP_ID=YOUR_APP_ID_HERE

# Private key: Download from GitHub App > Private keys section
# Keep as single line with \n for newlines
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# Webhook secret: Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here_generate_with_openssl

# ─── Security ─────────────────────────────────
CORS_ORIGIN=https://paycontrol.swiftwaveholding.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
